generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model UserProfile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  kibbe     String
  season    String
  essence   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
